# 通知渠道：dingtalk（钉钉，推荐）、wxpusher（个人微信）、dingtalk,wxpusher（同时推送）
NOTIFY_CHANNEL=dingtalk

# 钉钉群机器人 Webhook（NOTIFY_CHANNEL 含 dingtalk 时必填）
# 获取：群设置 → 智能群助手 → 添加机器人 → 自定义
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
# 若机器人安全设置为「加签」，填写 SECRET；选「自定义关键词」则留空
DINGTALK_SECRET=

# WxPusher 个人微信（NOTIFY_CHANNEL 含 wxpusher 时必填，免费）
# 获取：https://wxpusher.zjiecode.com → 创建应用 → 创建主题 → 微信扫码关注
WXPUSHER_APP_TOKEN=
WXPUSHER_TOPIC_IDS=
# 或直接填你的 UID（二选一，也可同时填）
WXPUSHER_UIDS=

# 监测关键词，逗号分隔
KEYWORDS=电池,新能源

# 轮询间隔（秒）
POLL_INTERVAL_SEC=60

# 每次拉取财联社电报条数
CLS_RN=20

# SQLite 状态库路径（可选）
STATE_DB_PATH=data/state.db
